{% extends 'base.html.twig' %}

{% block title %}ECHO — Ton compagnon bienveillant
{% endblock %}

{% block header %}{% endblock %}

{% block body %}

	<section class="font-inter flex min-h-screen bg-[#F0EEFF]">

		<aside class="hidden md:flex flex-col w-80 bg-[#F6F5FB] px-6 py-8 border-r border-gray-100 shrink-0 min-h-screen">

			<a href="{{ path('app_home') }}" class="flex items-center gap-2 text-sm text-gray-700 hover:text-primary transition font-medium mb-4">
				<span class="text-base">←</span>
				Retour
			</a>

			<div class="relative w-40 h-40 sm:w-56 sm:h-56 md:w-72 md:h-72 lg:w-[420px] lg:h-[420px]">
				<img src="{{ asset('images/Lumi_ECHO.png') }}" alt="ECHO" class="w-50 h-50 object-contain drop-shadow-sm mb-3"/>
				<h2 class="font-black text-2xl text-[#1E1B4B] tracking-wide mb-1">ECHO</h2>
				<p class="text-m text-gray-600 font-medium">Ton compagnon bienveillant</p>
			</div>

			<div class="bg-white border border-purple-100 rounded-3xl p-4 shadow-sm flex gap-3 items-start my-4">
				<div class="bg-[#EEEBFA] p-2 rounded-xl text-lg flex items-center justify-center">🔐</div>
				<div>
					<h3 class="font-bold text-sm text-gray-800">Conversation anonyme</h3>
					<p class="text-s text-gray-600 mt-1 leading-relaxed">Tout ce que tu dis ici reste confidentiel et sécurisé.</p>
				</div>
			</div>

			<div class="mt-4">
				<p class="text-s font-bold text-gray-600 uppercase tracking-wider mb-4">Liens rapides</p>

				<div class="flex flex-col gap-4">
					<a href="{{ path('app_signalement') }}" class="flex items-center gap-3 text-s font-semibold text-gray-600 hover:text-primary transition group">
						<span class="text-base bg-white shadow-sm w-7 h-7 flex items-center justify-center rounded-lg border border-gray-150">📄</span>
						<span class="group-hover:underline">Faire un signalement</span>
					</a>

					<a href="{{ path('app_home') }}#chaque-pas" class="flex items-center gap-3 text-s font-semibold text-gray-600 hover:text-primary transition group">
						<span class="text-base bg-white shadow-sm w-7 h-7 flex items-center justify-center rounded-lg border border-gray-150">⭐</span>
						<span class="group-hover:underline">Mes points Courage</span>
					</a>
				</div>
			</div>

			<div class="mt-auto pt-6">
				<div class="bg-[#FEE2E2] border border-[#FCA5A5] rounded-2xl py-2.5 px-4 flex items-center justify-center gap-2 shadow-sm cursor-pointer hover:bg-red-100 transition">
					<span class="text-red-600 text-sm">⚠️</span>
					<span class="font-extrabold text-[#991B1B] text-s tracking-wide">Urgence : 3018</span>
				</div>
			</div>
		</aside>


		{#
				    Contrôleur Stimulus du chat.
				
				    Les valeurs URL et CSRF sont transmises à JavaScript
				    afin d'envoyer les messages de manière sécurisée
				    vers le contrôleur Symfony.
				#}
		<section data-controller="chat" data-chat-url-value="{{ path('app_chat_message') }}" data-chat-csrf-token-value="{{ csrf_token('chat_message') }}" class="flex-1 flex flex-col min-w-0">
			<div class="w-full shrink-0 z-10 px-3 sm:px-4 mt-3 sm:mt-6">
				<div class="bg-white rounded-3xl shadow-sm py-4 sm:py-5 px-4 sm:px-6 w-full md:max-w-[98%] lg:max-w-[96%] mx-auto flex items-center justify-between">
					<div class="flex flex-col justify-center">
						<p class="font-black text-[#4A157D] text-sm italic tracking-wide uppercase font-sans">LUMI</p>
						<p class="text-xs text-gray-600 font-semibold flex items-center gap-2 mt-1">
							<span class="w-2.5 h-2.5 rounded-full bg-emerald-600 inline-block"></span>
							En ligne · Toujours là pour toi
						</p>
					</div>
				</div>
			</div>

			<div id="chat-messages" data-chat-target="chatMessages" aria-live="polite" aria-atomic="false" class="flex-1 overflow-y-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-6 flex flex-col w-full">

				{% if messages is empty %}
					<div id="welcome-screen" data-chat-target="welcomeScreen" class="w-full max-w-xl flex flex-col items-center justify-center gap-4 sm:gap-6 mt-2 md:-mt-8 mx-auto">

						<div class="relative w-36 h-36 sm:w-64 sm:h-64 md:w-80 md:h-80 lg:w-[440px] lg:h-[440px]">
							<img src="{{ asset('images/chat.png') }}" alt="Mascotte ECHO" class="w-full h-full object-contain animate-float relative z-10"/>
						</div>

						<div class="text-center -mt-10 sm:-mt-16 md:-mt-24">
							<h1 class="font-black text-2xl sm:text-3xl md:text-4xl text-[#1E1B4B] tracking-tight">
								Salut 💜
							</h1>

							<p class="text-gray-600 text-sm md:text-base font-semibold mt-2 leading-relaxed">
								Je suis ECHO. Tu peux tout me dire ici,<br class="hidden sm:block">
								en toute confidentialité.
							</p>
						</div>

						<div class="w-full max-w-sm bg-white border border-purple-100 rounded-2xl px-4 py-3 shadow-sm">
							<p class="text-xs text-gray-600 leading-relaxed text-center">
								🔒
								<strong>Ta confidentialité est protégée.</strong><br>
								Si tu es en danger immédiat, ECHO peut alerter un adulte de confiance pour t'aider —
								<span class="text-[#A855F7] font-semibold">toujours pour te protéger 💜</span>
							</p>
						</div>

						<div class="flex flex-col gap-3 w-full mt-3 sm:mt-4">
							<button type="button" data-action="click->chat#quickMessage" class="quick-action-btn group flex items-center justify-between bg-white border-2 border-purple-100 rounded-full px-4 sm:px-6 py-3 sm:py-3.5 shadow-sm hover:border-primary hover:bg-purple-50/30 transition-all duration-200 text-left w-full" data-message="J'ai un problème à l'école">
								<div class="flex items-center gap-3 sm:gap-4">
									<img src="{{ asset('images/School.png') }}" alt="École" class="w-6 h-6 sm:w-7 sm:h-7 object-contain"/>
									<span class="text-[#1E1B4B] font-black text-xs sm:text-sm">J'ai un problème à l'école</span>
								</div>
								<span class="text-purple-300 group-hover:text-primary transition font-bold">→</span>
							</button>

							<button type="button" data-action="click->chat#quickMessage" class="quick-action-btn group flex items-center justify-between bg-white border-2 border-purple-100 rounded-full px-4 sm:px-6 py-3 sm:py-3.5 shadow-sm hover:border-primary hover:bg-purple-50/30 transition-all duration-200 text-left w-full" data-message="Je veux signaler quelque chose">
								<div class="flex items-center gap-3 sm:gap-4">
									<img src="{{ asset('images/Commercial.png') }}" alt="Signaler" class="w-6 h-6 sm:w-7 sm:h-7 object-contain"/>
									<span class="text-[#1E1B4B] font-black text-xs sm:text-sm">Je veux signaler quelque chose</span>
								</div>
								<span class="text-purple-300 group-hover:text-primary transition font-bold">→</span>
							</button>

							<button type="button" data-action="click->chat#quickMessage" class="quick-action-btn group flex items-center justify-between bg-white border-2 border-purple-100 rounded-full px-4 sm:px-6 py-3 sm:py-3.5 shadow-sm hover:border-primary hover:bg-purple-50/30 transition-all duration-200 text-left w-full" data-message="J'ai juste besoin de parler">
								<div class="flex items-center gap-3 sm:gap-4">
									<img src="{{ asset('images/ChatP.png') }}" alt="Parler" class="w-6 h-6 sm:w-7 sm:h-7 object-contain"/>
									<span class="text-[#1E1B4B] font-black text-xs sm:text-sm">J'ai juste besoin de parler</span>
								</div>
								<span class="text-purple-300 group-hover:text-primary transition font-bold">→</span>
							</button>
						</div>

						<div class="w-full mt-2">
							<div class="bg-[#CCAFE7]/30 backdrop-blur-sm rounded-full py-3 px-5 sm:px-12 text-center border border-[#CCAFE7]/40 flex items-center justify-center shadow-inner">
								<p class="text-[#6B21A8] text-xs md:text-sm font-black tracking-wide">
									💜 Tout ce que tu dis ici reste confidentiel
								</p>
							</div>
						</div>
					</div>
				{% endif %}

				<div id="real-messages-container" data-chat-target="realMessagesContainer" class="flex flex-col gap-4 w-full max-w-5xl mx-auto px-3 sm:px-4 md:px-8">
					{% for msg in messages %}
						{% if msg.sender == 'user' %}
							<div class="flex justify-end w-full mb-1">
								<div class="bg-primary-light text-white rounded-3xl rounded-br-sm py-3 px-4 sm:py-3.5 sm:px-6 max-w-[85%] md:max-w-[60%] text-sm md:text-base shadow-sm font-semibold tracking-wide leading-relaxed break-words">
									{{ msg.content }}
								</div>
							</div>
						{% else %}
							<div class="flex justify-start items-end gap-2 sm:gap-3 w-full mb-1">
								<img src="{{ asset('images/logo.png') }}" class="w-8 h-8 sm:w-9 sm:h-9 object-contain shrink-0 mb-1" alt="" aria-hidden="true"/>

								<div class="flex flex-col max-w-[85%] md:max-w-[60%]">
									<div class="bg-white border border-purple-100/60 rounded-3xl rounded-bl-sm py-3 px-4 sm:py-3.5 sm:px-6 shadow-sm text-[#1E1B4B] text-sm md:text-base font-semibold tracking-wide leading-relaxed break-words">
										{{ msg.content }}

										{% if msg.isAlert %}
											<div class="mt-2.5 bg-red-50 border border-red-100 rounded-xl px-3 py-2 text-xs text-red-600 font-bold">
												⚠️ Si tu es en danger, appelle le 3018
											</div>
										{% endif %}
									</div>
								</div>
							</div>
						{% endif %}
					{% endfor %}
				</div>

				<div id="typing-indicator" data-chat-target="typingIndicator" class="hidden flex justify-start gap-3 items-end mt-6 max-w-4xl mx-auto w-full px-3 sm:px-4 md:px-8">
					<img src="{{ asset('images/logo.png') }}" class="w-8 h-8 sm:w-9 sm:h-9 object-contain shrink-0" alt="" aria-hidden="true"/>

					<div class="bg-white rounded-3xl rounded-bl-sm py-3.5 px-6 shadow-sm flex items-center justify-center">
						<div class="flex gap-1.5 items-center h-5">
							<span class="w-2 h-2 bg-[#A855F7] rounded-full animate-bounce [animation-delay:0ms]"></span>
							<span class="w-2 h-2 bg-[#A855F7] rounded-full animate-bounce [animation-delay:200ms]"></span>
							<span class="w-2 h-2 bg-[#A855F7] rounded-full animate-bounce [animation-delay:400ms]"></span>
						</div>
					</div>
				</div>
			</div>

			<div class="w-full flex-shrink-0 bg-transparent px-3 sm:px-6 pb-3 sm:pb-4">
				<div class="w-full mx-auto flex items-center gap-2 bg-transparent">

					<button type="button" class="flex flex-shrink-0 items-center justify-center gap-2 px-3 sm:px-6 md:px-12 h-12 bg-[#FEE2E2] border border-[#FCA5A5] rounded-full text-[#991B1B] font-black text-xs sm:text-sm shadow-sm hover:bg-red-100 transition-all duration-200">
						<span class="text-base">⚠️</span>
						<span class="hidden sm:inline">Signaler</span>
					</button>


					{#
					    Champ de saisie du chat.
					
					    Le contrôleur Stimulus récupère automatiquement
					    ce champ grâce au target "chatInput".
					#}

					<div class="flex-1 relative flex items-center">
						<input id="chat-input" data-chat-target="chatInput" data-action="keydown->chat#handleKey" type="text" placeholder="Écris ton message ..." class="w-full h-14 sm:h-16 bg-white border-2 border-purple-100 rounded-full pl-5 sm:pl-6 pr-16 sm:pr-20 text-sm sm:text-base font-semibold text-[#1E1B4B] placeholder:text-gray-600 shadow-sm focus:outline-none focus:border-primary-light focus:ring-2 focus:ring-primary-light/10 transition-all"/>

						<button id="send-btn" aria-label="Envoyer le message" data-chat-target="sendBtn" data-action="click->chat#sendMessage" type="button" class="absolute right-2 top-1/2 -translate-y-1/2 bg-primary-light flex items-center justify-center rounded-full hover:bg-[#9333EA] shadow-md transition-all duration-200 w-10 h-10 sm:w-12 sm:h-12">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white pl-0.5" fill="currentColor" viewbox="0 0 24 24">
								<path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
							</svg>
						</button>
					</div>
				</div>
			</div>

			<div class="md:hidden bg-red-50 border-t rounded-2xl border-red-100 px-4 py-3 flex items-center justify-center gap-2">
				<span class="font-bold text-red-600 text-xs">Urgence : 3018</span>
			</div>
		</section>
	</section>

{% endblock %}
