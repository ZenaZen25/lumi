<header data-controller="navbar" class="w-full max-w-[1238px] mx-auto bg-white shadow-sm rounded-[25px] mt-6 relative z-50">

	<nav
		class="flex items-center justify-between px-4 py-4 md:px-8">

		{# Logo #}
		<a href="{{ path('app_home') }}" class="flex items-center gap-2 hover:opacity-90 transition focus:outline-none">
			<img src="{{ asset('images/logo.png') }}" alt="Lumi Logo" class="w-8 h-8 lg:w-10 lg:h-10 object-contain">
			<span class="font-inter font-bold text-[#4A157D] text-lg lg:text-xl italic">LUMI</span>
		</a>

		{# Menu desktop seulement #}
		<div class="hidden lg:flex items-center gap-8">
			<a href="{{ path('app_chat') }}" class="hover:opacity-80 font-semibold text-sm text-[#4A157D]">
				Parler à Echo
			</a>

			<a href="{{ path('app_profil') }}" class="hover:opacity-80 font-semibold text-sm text-[#4A157D]">
				Mes points
			</a>

			<a href="{{ path('app_signalement') }}" class="hover:opacity-80 font-semibold text-sm text-[#4A157D]">
				Faire un signalement
			</a>

			{% if app.user %}

				<div class="flex items-center gap-4">

					<span class="text-sm font-semibold text-[#4A157D]">
						Bonjour
						{{ app.user.prenom }}
					</span>

					<a href="{{ path('app_logout') }}" class="bg-[#C084FC] text-white px-6 py-3 rounded-full font-bold">
						Se déconnecter
					</a>

				</div>

			{% else %}

				<a href="{{ path('app_login') }}" class="bg-[#C084FC] text-white px-6 py-3 rounded-full font-bold">
					Se connecter
				</a>

			{% endif %}
		</div>

		{# Burger mobile + tablette #}
		<button type="button" data-action="click->navbar#toggle" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Ouvrir le menu">

			<span class="w-6 h-0.5 bg-[#4A157D] rounded-full"></span>
			<span class="w-6 h-0.5 bg-[#4A157D] rounded-full"></span>
			<span class="w-6 h-0.5 bg-[#4A157D] rounded-full"></span>
		</button>

	</nav>

	{# Menu mobile/tablette #}
	<div data-navbar-target="menu" class="hidden lg:hidden px-6 pb-6">

		<div class="flex flex-col gap-4 bg-[#F0EEFF] rounded-2xl p-5">

			<a href="{{ path('app_chat') }}" class="font-semibold text-sm text-[#4A157D]">
				Parler à Echo
			</a>

			<a href="{{ path('app_profil') }}" class="font-semibold text-sm text-[#4A157D]">
				Mes points
			</a>

			<a href="{{ path('app_signalement') }}" class="font-semibold text-sm text-[#4A157D]">
				Faire un signalement
			</a>

			{% if not app.user %}
				<a href="{{ path('app_login') }}" class="bg-[#A855F7] text-white text-center px-5 py-2 rounded-full font-semibold text-sm">
					Se connecter
				</a>
			{% endif %}

		</div>
	</div>

</header>
