								<div class="text-3xl lg:text-4xl mb-4">⭐</div>
								<div>
									<div class="font-inter font-bold text-sm lg:text-lg text-[#2D2D2D]">Premier Pas</div>
									<div class="text-[11px] lg:text-sm text-gray-400 mt-1 font-normal">Tu as osé parler</div>
								</div>
							</div>
							<div class="bg-white rounded-[32px] p-6 lg:p-8 shadow-sm border border-gray-100/50 flex flex-col justify-between items-start min-h-[160px] lg:min-h-[190px] hover:scale-[1.02] transition-transform">
								<div class="text-3xl lg:text-4xl mb-4">🦁</div>
								<div>
									<div class="font-inter font-bold text-sm lg:text-lg text-[#2D2D2D]">Courage</div>
									<div class="text-[11px] lg:text-sm text-gray-400 mt-1 font-normal">Tu affrontes tes peurs</div>
								</div>
							</div>
							<div class="bg-white rounded-[32px] p-6 lg:p-8 shadow-sm border border-gray-100/50 flex flex-col justify-between items-start min-h-[160px] lg:min-h-[190px] hover:scale-[1.02] transition-transform">
								<div class="text-3xl lg:text-4xl mb-4">🤝</div>
								<div>
									<div class="font-inter font-bold text-sm lg:text-lg text-[#2D2D2D]">Pas Seul·e</div>
									<div class="text-[11px] lg:text-sm text-gray-400 mt-1 font-normal">Tu as demandé de l'aide</div>
