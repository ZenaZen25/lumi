							<img src="{{ asset('images/MOBILE-ECHO.png') }}" alt="Interface de discussion sur smartphone avec ECHO" class="w-full h-auto object-contain border-4 border-black rounded-[32px] shadow-xl">
						</div>
					</div>
				</div>
			</section>

			{# CHAQUE PAS COMPTE #}
