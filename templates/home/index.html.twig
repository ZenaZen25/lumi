								                        w-full h-14 text-base rounded-[24px]
								                        sm:w-[220px] sm:h-14 sm:text-sm
								                        md:w-[260px] md:h-16 md:text-lg md:rounded-[32px]
								                        lg:w-[320px] lg:h-[80px] lg:text-[32px] lg:rounded-[50px]">
							💬 Parler à ECHO
						</a>
						<a href="{{ path('app_chat_anonymous') }}" class="border-2 border-[#20736D] text-[#20736D] bg-white/50 flex items-center justify-center font-semibold hover:bg-white transition shadow-sm focus:outline-none focus:ring-2 focus:ring-[#20736D] focus:ring-offset-2
								                        w-full h-14 text-base rounded-[24px]
								                        sm:w-[220px] sm:h-14 sm:text-sm
								                        md:w-[260px] md:h-16 md:text-lg md:rounded-[32px]
								                        lg:w-[320px] lg:h-[80px] lg:text-[32px] lg:rounded-[50px]">
