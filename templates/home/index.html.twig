							</div>
							<div class="bg-white rounded-[32px] p-6 lg:p-8 shadow-sm border border-gray-100/50 flex flex-col justify-between items-start min-h-[160px] lg:min-h-[190px] hover:scale-[1.02] transition-transform">
								<div class="text-3xl lg:text-4xl mb-4">🕊️</div>
								<div>
									<div class="font-inter font-bold text-sm lg:text-lg text-[#2D2D2D]">Voix Libre</div>
									<div class="text-[11px] lg:text-sm text-gray-400 mt-1 font-normal">Tu t'es exprimé·e</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			{# SECURITE #}
			<section class="bg-gradient-to-b from-[#F0EEFF] to-[#F1EAFA] py-16 px-6 md:py-24 md:px-8 text-center" aria-labelledby="security-title">
				<div class="max-w-7xl mx-auto">
					<h2 id="security-title" class="font-inter font-bold text-3xl md:text-5xl lg:text-[64px] text-gray-700 mb-4 lg:mb-6 tracking-tight leading-tight lg:leading-none">
