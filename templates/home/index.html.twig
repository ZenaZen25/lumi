					<p class="text-gray-500 text-sm sm:text-base md:text-xl lg:text-[32px] font-normal md:font-semibold leading-relaxed lg:leading-[46px] mb-12 lg:mb-16 max-w-sm md:max-w-3xl lg:max-w-5xl mx-auto">
