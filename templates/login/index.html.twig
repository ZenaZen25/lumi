{% extends 'base.html.twig' %}

{% block title %}Connexion — LUMI
{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
	<div class="min-h-screen bg-gradient-to-b from-[#F0EEFF] to-[#F1EAFA] font-inter">

		{% include '_partials/_header.html.twig' %}

		<section class="flex flex-col items-center px-4 pt-8 mb-6">
			<div class="relative w-48 h-48 sm:w-64 sm:h-64 md:w-80 md:h-80 lg:w-[360px] lg:h-[360px]">
				<img src="{{ asset('images/chat.png') }}" alt="Mascotte ECHO" class="w-full h-full object-contain animate-float relative z-10"/>
			</div>

			<h1 class="font-inter font-bold text-4xl text-[#4A157D] -mt-8">
				LUMI 💜
			</h1>

			<p class="text-gray-600 text-xl text-center max-w-xl mt-2">
				Une plateforme bienveillante pour parler de harcèlement et d'intimidation à l'école.
			</p>
		</section>

		<div id="login-form" class="flex flex-col md:flex-row justify-center gap-3 mb-8 px-4 w-full max-w-3xl mx-auto">
			<a href="#login-form" onclick="document.getElementById('login_type').value='eleve'" class="w-full md:flex-1 text-center bg-[#A855F7] text-white py-3 rounded-full font-bold text-sm md:text-base shadow">
				Je suis un élève
			</a>

			<a href="#login-form" onclick="document.getElementById('login_type').value='admin'" class="w-full md:flex-1 text-center border-2 border-[#20736D] text-[#20736D] py-3 rounded-full font-bold text-sm md:text-base hover:bg-white transition">
				Référent / Admin
			</a>
		</div>

		<section class="flex justify-center px-4 mb-16" aria-labelledby="login-title">
			<div class="bg-white rounded-3xl shadow-md p-8 sm:p-10 w-full max-w-3xl">

				<h2 id="login-title" class="sr-only">
					Formulaire de connexion
				</h2>

				{% if error %}
					<div id="error-msg" role="alert" class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-4 text-sm font-semibold">
						{{ error.messageKey | trans(error.messageData, 'security') }}
					</div>
				{% endif %}

				<div class="bg-[#EDE0FF] rounded-2xl px-6 py-4 text-center text-[#4A157D] font-semibold text-base mb-6">
					Tu peux aussi utiliser LUMI sans compte
				</div>

				<form method="post" action="{{ path('app_login') }}">
					<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
					<input type="hidden" id="login_type" name="login_type" value="eleve">

					<div class="mb-4">
						<label for="username" class="block text-sm font-semibold text-gray-700 mb-2">


							<label for="username" class="block text-sm font-semibold text-gray-700 mb-2">
								Adresse e-mail
							</label>
						</label>

						<input type="text" id="username" name="_username" value="{{ last_username }}" placeholder="ex. Zena" class="w-full border border-gray-200 rounded-2xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#A855F7] bg-gray-50" autocomplete="username" {% if error %} aria-describedby="error-msg" {% endif %}>
					</div>

					<div class="mb-6">
						<label for="password" class="block text-sm font-semibold text-gray-700 mb-2">
							Mot de passe
						</label>

						<input type="password" id="password" name="_password" placeholder="ton mot de passe" class="w-full border border-gray-200 rounded-2xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#A855F7] bg-gray-50" autocomplete="current-password" {% if error %} aria-describedby="error-msg" {% endif %}>
					</div>

					<button type="submit" class="w-full bg-[#A855F7] text-white py-4 rounded-2xl font-bold text-base hover:opacity-90 transition shadow-md">
						Se connecter
					</button>
				</form>

				<div class="text-center mt-6">
					<a href="{{ path('app_chat_anonymous') }}" class="text-[#A855F7] font-semibold text-base hover:underline">
						Continuer sans compte →
					</a>
				</div>

				<p class="text-center text-base text-gray-600 mt-2">
					Crée un compte élève
				</p>
			</div>
		</section>
	</div>
{% endblock %}
