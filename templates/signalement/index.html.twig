{% extends 'base.html.twig' %}

{% block title %}LUMI — Faire un signalement
{% endblock %}

{% block body %}


	{# HEADER #}
	<div
		data-controller="signalement" class="min-h-screen bg-[#F0EEFF] font-inter px-4 py-6 flex flex-col items-center">


		{# PROGRESS BAR #}

		<div class="w-full max-w-4xl rounded-3xl px-6 py-5  mb-8">


			<div class="flex gap-2 mb-2" role="progressbar" aria-label="Progression du signalement" aria-valuemin="1" aria-valuemax="4" aria-valuenow="1" data-signalement-target="progress">

				<div data-signalement-target="stepBar" class="step-bar h-2 flex-1 rounded-full transition-all bg-primary-light" data-step="1"></div>

				<div data-signalement-target="stepBar" class="step-bar h-2 flex-1 rounded-full transition-all bg-[#D8B4FE]" data-step="2"></div>

				<div data-signalement-target="stepBar" class="step-bar h-2 flex-1 rounded-full transition-all bg-[#D8B4FE]" data-step="3"></div>

				<div data-signalement-target="stepBar" class="step-bar h-2 flex-1 rounded-full transition-all bg-[#D8B4FE]" data-step="4"></div>

			</div>

			<p data-signalement-target="stepLabel" id="step-label" class="text-xs text-gray-400 font-semibold mt-1">Étape 1 sur 4</p>

		</div>

		{# MASCOTTE #}
		<div class="flex justify-center mb-6" aria-hidden="true">

			<div class="relative w-64 h-64 md:w-80 md:h-80 lg:w-96 lg:h-96">

				<img src="{{ asset('images/echo.png') }}" alt="ECHO" class="w-full h-full object-contain animate-float"/>

			</div>

		</div>

		{# ===== STEP 1 ===== #}
		<div id="step-1" data-signalement-target="step" data-step="1" aria-hidden="false" class="w-full max-w-4xl">
			<div class="text-center mb-6">
				<h2 class="font-black text-4xl text-[#1E1B4B] mb-1">Qu'est-ce qui se passe ?</h2>
				<p class="text-xl text-gray-400 font-medium">Choisis ce qui correspond le mieux à ta situation</p>
			</div>
			<div class="grid grid-cols-2 gap-4 mb-8">

				<button type="button" aria-label="Harcèlement verbal" data-signalement-target="typeCard" data-action="click->signalement#selectType" class="type-card bg-white rounded-2xl p-5 shadow-sm border-2 border-transparent hover:border-primary-light transition-all text-left" data-value="verbal">

					<div class="text-3xl mb-3">💬</div>
					<div class="font-black text-sm text-[#1E1B4B] mb-1">Verbal</div>
					<div class="text-xs text-gray-400">Moqueries, insultes, rumeurs</div>

				</button>

				<button type="button" aria-label="Harcèlement physique" data-signalement-target="typeCard" data-action="click->signalement#selectType" class="type-card bg-white rounded-2xl p-5 shadow-sm border-2 border-transparent hover:border-primary-light transition-all text-left" data-value="physique">

					<div class="text-3xl mb-3">👊</div>
					<div class="font-black text-sm text-[#1E1B4B] mb-1">Physique</div>
					<div class="text-xs text-gray-400">Coups, bousculades, vols</div>

				</button>

				<button type="button" aria-label="Cyberharcèlement" data-signalement-target="typeCard" data-action="click->signalement#selectType" class="type-card bg-white rounded-2xl p-5 shadow-sm border-2 border-transparent hover:border-primary-light transition-all text-left" data-value="cyberharcelement">

					<div class="text-3xl mb-3">📱</div>
					<div class="font-black text-sm text-[#1E1B4B] mb-1">Cyberharcèlement</div>
					<div class="text-xs text-gray-400">Messages, réseaux sociaux</div>

				</button>

				<button type="button" aria-label="Exclusion" data-signalement-target="typeCard" data-action="click->signalement#selectType" class="type-card bg-white rounded-2xl p-5 shadow-sm border-2 border-transparent hover:border-primary-light transition-all text-left" data-value="exclusion">

					<div class="text-3xl mb-3">🚪</div>
					<div class="font-black text-sm text-[#1E1B4B] mb-1">Exclusion</div>
					<div class="text-xs text-gray-400">Mise à l'écart, ignorance</div>

				</button>

			</div>

			<div class="flex justify-end">

				<p id="type-help" class="sr-only">
					Sélectionne un type de harcèlement pour continuer.
				</p>
				<button type="button" id="next-1" aria-describedby="type-help" data-signalement-target="next1" data-action="click->signalement#goStep2" disabled class="bg-primary-light text-white px-10 py-3 rounded-full font-black text-sm shadow hover:bg-[#9333EA] transition disabled:opacity-40 disabled:cursor-not-allowed">

					Continuer

				</button>

			</div>
		</div>

		{# ===== STEP 2 ===== #}
		<div id="step-2" data-signalement-target="step" data-step="2" aria-hidden="true" class="w-full max-w-4xl hidden">
			<div class="text-center mb-6">
				<h2 class="font-black text-2xl text-[#1E1B4B] mb-1">Où et quand ?</h2>
				<p class="text-sm text-gray-400 font-medium">Ces infos nous aident à mieux comprendre la situation</p>
			</div>

			<div class="bg-white rounded-2xl p-6 shadow-sm mb-4">
				<label class="block text-sm font-black text-[#1E1B4B] mb-3">
					Où ça s'est passé ?
					<span class="text-gray-400 font-normal">(optionnel)</span>
				</label>

				<input id="input-zone" data-signalement-target="zoneInput" type="text" placeholder="Ex: cour de récré, couloire, cantine ..." class="w-full h-12 bg-[#F8F5FF] border border-purple-100 rounded-full px-5 text-sm text-[#1E1B4B] placeholder:text-gray-400 focus:outline-none focus:border-primary-light transition"/>
			</div>

			<div class="bg-white rounded-2xl p-6 shadow-sm mb-8">
				<label class="block text-sm font-black text-[#1E1B4B] mb-3">À quelle fréquence ?</label>

				<div class="flex gap-3 flex-wrap">
					<button type="button" aria-label="Une fois" data-signalement-target="freqButton" data-action="click->signalement#selectFrequence" class="freq-btn border-2 border-gray-200 rounded-full px-5 py-2 text-sm font-black text-gray-600 hover:border-primary-light hover:text-primary-light transition" data-value="une_fois">
						Une fois
					</button>

					<button type="button" aria-label="Plusieurs fois" data-signalement-target="freqButton" data-action="click->signalement#selectFrequence" class="freq-btn border-2 border-gray-200 rounded-full px-5 py-2 text-sm font-black text-gray-600 hover:border-primary-light hover:text-primary-light transition" data-value="plusieurs_fois">
						Plusieurs fois
					</button>

					<button type="button" aria-label="Tous les jours" data-signalement-target="freqButton" data-action="click->signalement#selectFrequence" class="freq-btn border-2 border-gray-200 rounded-full px-5 py-2 text-sm font-black text-gray-600 hover:border-primary-light hover:text-primary-light transition" data-value="tous_les_jours">
						Tous les jours
					</button>
				</div>
			</div>

			<div class="flex justify-between items-center">
				<button type="button" aria-label="Retour" data-action="click->signalement#previous" class="btn-prev text-sm text-gray-400 hover:text-gray-600 font-semibold transition">
					← Retour
				</button>

				<p id="freq-help" class="sr-only">
					Sélectionne une fréquence pour continuer.
				</p>

				<button type="button" id="next-2" aria-describedby="freq-help" aria-label="Continuer" data-signalement-target="next2" data-action="click->signalement#goStep3" disabled class="bg-primary-light text-white px-10 py-3 rounded-full font-black text-sm shadow hover:bg-[#9333EA] transition disabled:opacity-40 disabled:cursor-not-allowed">
					Continuer
				</button>
			</div>
		</div>
		{# ===== STEP 3 ===== #}
		<div id="step-3" data-signalement-target="step" data-step="3" aria-hidden="true" class="w-full max-w-4xl hidden">
			<div class="text-center mb-6">
				<h2 class="font-black text-2xl text-[#1E1B4B] mb-1">Raconte-nous</h2>
				<p class="text-sm text-gray-400 font-medium">Tu peux en dire autant ou aussi peu que tu veux</p>
			</div>

			<textarea id="input-description" data-signalement-target="descriptionInput" rows="6" placeholder="Décris ce qui s'est passé, comment tu te sens..." class="w-full bg-white border border-purple-100 rounded-2xl p-5 text-sm text-[#1E1B4B] placeholder:text-gray-400 focus:outline-none focus:border-primary-light shadow-sm transition resize-none mb-4"></textarea>

			<div class="bg-[#EDE9FA] rounded-2xl px-5 py-4 mb-8 flex gap-3 items-start">
				<span class="text-base">💜</span>
				<div>
					<div class="font-black text-xs text-primary mb-1">Conseil d'ECHO</div>
					<div class="text-xs text-[#6B21A8] leading-relaxed">
						Il n'y a pas de bonne ou mauvaise façon de s'exprimer. L'important, c'est que tu te sentes écouté·e.
					</div>
				</div>
			</div>

			<div class="flex justify-between items-center">
				<button type="button" aria-label="Retour" data-action="click->signalement#previous" class="btn-prev text-sm text-gray-400 hover:text-gray-600 font-semibold transition">
					← Retour
				</button>

				<p id="description-help" class="sr-only">
					Écris une description de ton expérience.
				</p>

				<button type="button" id="next-3" aria-describedby="description-help" aria-label="Continuer" data-action="click->signalement#goStep4" class="bg-primary-light text-white px-10 py-3 rounded-full font-black text-sm shadow hover:bg-[#9333EA] transition">
					Continuer
				</button>
			</div>
		</div>

		{# ===== STEP 4 — RÉCAPITULATIF ===== #}
		<div id="step-4" data-signalement-target="step" data-step="4" aria-hidden="true" class="w-full max-w-4xl hidden">
			<div class="text-center mb-6">
				<h2 class="font-black text-2xl text-[#1E1B4B] mb-1">Récapitulatif</h2>
				<p class="text-sm text-gray-400 font-medium">Vérifie que tout est correct avant d'envoyer</p>
			</div>

			<div class="bg-white rounded-2xl shadow-sm divide-y divide-gray-100 mb-8">
				<div class="flex justify-between items-center px-6 py-4">
					<span class="text-sm text-gray-400 font-semibold">Type</span>
					<span id="recap-type" data-signalement-target="recapType" class="text-sm font-black text-[#1E1B4B]"></span>
				</div>

				<div class="flex justify-between items-center px-6 py-4">
					<span class="text-sm text-gray-400 font-semibold">Fréquence</span>
					<span id="recap-frequence" data-signalement-target="recapFrequence" class="text-sm font-black text-[#1E1B4B]"></span>
				</div>

				<div id="recap-zone-row" data-signalement-target="recapZoneRow" class="hidden flex justify-between items-center px-6 py-4">
					<span class="text-sm text-gray-400 font-semibold">Lieu</span>
					<span id="recap-zone" data-signalement-target="recapZone" class="text-sm font-black text-[#1E1B4B]"></span>
				</div>
			</div>

			<form method="POST" action="{{ path('app_signalement_submit') }}">

				<input type="hidden" name="_token" value="{{ csrf_token('signalement_submit') }}">

				<input type="hidden" name="type" id="hidden-type" data-signalement-target="hiddenType">
				<input type="hidden" name="zone" id="hidden-zone" data-signalement-target="hiddenZone">
				<input type="hidden" name="frequence" id="hidden-frequence" data-signalement-target="hiddenFrequence">
				<input type="hidden" name="description" id="hidden-description" data-signalement-target="hiddenDescription">

				<button type="submit" class="w-full bg-primary-light text-white py-4 rounded-full font-black text-base shadow-lg hover:bg-[#9333EA] transition mb-4">
					Envoyer mon signalement
				</button>
			</form>

			<div class="flex justify-start">
				<button type="button" aria-label="Retour" data-action="click->signalement#previous" class="btn-prev text-sm text-gray-400 hover:text-gray-600 font-semibold transition">
					← Retour
				</button>
			</div>
		</div>


	{% endblock %}
