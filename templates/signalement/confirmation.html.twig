{% extends 'base.html.twig' %}

{% block title %}LUMI — Signalement envoyé
{% endblock %}

{% block header %}{% endblock %}

{% block body %}
	<div class="min-h-screen bg-gradient-to-b from-[#F0EEFF] to-[#F1EAFA] font-inter flex items-center justify-center px-4 py-8 text-center">

		<div
			class="w-full max-w-2xl flex flex-col items-center -mt-8">

			{# MASCOTTE #}
			<div class="flex justify-center mb-6" aria-hidden="true">

				<div class="relative w-64 h-64 md:w-80 md:h-80 lg:w-96 lg:h-96">

					<img src="{{ asset('images/Lumi_ECHO.png') }}" alt="ECHO" class="w-full h-full object-contain animate-float"/>

				</div>

			</div>
			<div class="text-5xl mb-4 -m-12">🎉</div>

			<div class="flex flex-col items-center gap-8 mb-8">

			<h1 class="font-bold text-3xl md:text-4xl text-[#1E1B4B] mb-5 leading-tight">
				Ton signalement a bien été<br>
				envoyé 💜
			</h1>

			<p class="font-medium text-lg md:text-xl text-gray-500 mb-8 max-w-xl leading-relaxed">
				Merci pour ton courage. Un adulte de confiance va<br class="hidden md:block">
				examiner ta situation rapidement.
			</p>
			<div class="flex flex-col items-center gap-8">

				{% if isLoggedIn %}
					<div class="bg-yellow-400 rounded-full px-8 py-4 font-bold">
						+50 pts de Courage ⭐
					</div>
				{% else %}
					<div class="bg-white rounded-full px-8 py-4 text-[#4A157D] font-semibold shadow-sm">
						Signalement anonyme envoyé 🔒
					</div>
				{% endif %}

			</div>

			<div class="flex gap-4 flex-wrap justify-center">
				<a href="{{ path('app_home') }}" class="border-2 border-[#20736D] text-[#20736D] bg-white/60 px-8 py-3 rounded-full font-black text-base hover:bg-white transition">
					Retour à l'accueil
				</a>

				<a href="{{ path('app_chat') }}" class="bg-[#A855F7] text-white px-10 py-3 rounded-full font-black text-base shadow hover:bg-[#9333EA] transition">
					Parler à ECHO
				</a>
			</div>
			<div>

		</div>
	</div>
{% endblock %}
