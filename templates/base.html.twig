<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8">

		{# Permet d’adapter l’affichage aux téléphones, tablettes et ordinateurs #}
		<meta name="viewport" content="width=device-width, initial-scale=1.0">

		{# Titre de la page, modifiable dans chaque template enfant #}
		<title>
			{% block title %}LUMI{% endblock %}
		</title>

		{# Chargement de la police Inter depuis Google Fonts #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

		{# Chargement du fichier CSS principal #}
		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('app.css') }}">
		{% endblock %}

		{# Chargement des fichiers JavaScript avec Importmap #}
		{% block javascripts %}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}

		{# Active le rechargement automatique de la page avec FrankenPHP en développement #}
		{% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
		{% if frankenphpHotReload %}
			<meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
			<script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
			<script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
		{% endif %}
	</head>

	<body class="bg-gradient-to-b from-[#F0EEFF] to-[#F1EAFA] min-h-screen flex flex-col">

		{# 
			Lien d’évitement pour l’accessibilité.
			Il permet aux personnes qui utilisent le clavier ou un lecteur d’écran
			d’aller directement au contenu principal.
		#}
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 bg-white text-[#1E1B4B] px-4 py-2 rounded-lg shadow"
		>
			Aller au contenu principal
		</a>

		{# Affiche l’en-tête principal du site #}
		{% block header %}
			{% include '_partials/_header.html.twig' %}
		{% endblock %}

		{# Affiche la bannière de gestion des cookies #}
		{% block cookie_banner %}
			{% include '_partials/_cookie_banner.html.twig' %}
		{% endblock %}

		{# Zone principale de la page #}
		<main id="main-content" class="flex-grow">
			{% block body %}{% endblock %}
		</main>

		{# Affiche le pied de page #}
		{% include '_partials/_footer.html.twig' %}

	</body>
</html>